@page "/minute-sheets/create"
@using MinuteSheetFFC.Application.DTOs.MinuteSheet
@inject MinuteSheetFFC.Web.Services.ApiClient Api
@inject MinuteSheetFFC.Web.State.AppState State
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Create Minute Sheet</PageTitle>
<h3 class="mb-3">Create New Minute Sheet</h3>

@if (!string.IsNullOrEmpty(error))
{ <div class="alert alert-danger">@error</div> }

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-8">
                <label class="form-label">Subject</label>
                <input type="text" class="form-control" @bind="model.Subject" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Request Type</label>
                <select class="form-select" @bind="model.RequestTypeId">
                    <option value="1">Financial</option>
                    <option value="2">Non-Financial</option>
                    <option value="3">Human Resources</option>
                    <option value="4">Information Technology</option>
                    <option value="5">Procurement</option>
                    <option value="6">Administrative</option>
                </select>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Estimated Budget (PKR)</label>
                <input type="number" class="form-control" @bind="model.EstimatedBudget" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Priority</label>
                <select class="form-select" @bind="model.Priority">
                    <option value="LOW">Low</option>
                    <option value="NORMAL" selected>Normal</option>
                    <option value="HIGH">High</option>
                    <option value="URGENT">Urgent</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Workflow Mode</label>
                <select class="form-select" @bind="model.WorkflowMode">
                    <option value="DYNAMIC" selected>Dynamic (Auto)</option>
                    <option value="MANUAL">Manual</option>
                    <option value="HYBRID">Hybrid</option>
                </select>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Body / Details</label>
            <textarea class="form-control" rows="8" @bind="model.Body"></textarea>
            <small class="text-muted">HTML is supported for rich text.</small>
        </div>
        <div class="mb-3">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" @bind="model.IsConfidential" />
                <label class="form-check-label">Mark as Confidential</label>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="SaveDraft" disabled="@saving">Save as Draft</button>
            <button class="btn btn-success" @onclick="SaveAndSubmit" disabled="@saving">Save & Submit</button>
            <a href="/minute-sheets" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</div>

@code {
    private CreateMinuteSheetDto model = new() { RequestTypeId = 2, Priority = "NORMAL", WorkflowMode = "DYNAMIC" };
    private string? error;
    private bool saving;

    private async Task SaveDraft()
    {
        saving = true;
        error = null;
        model.RequesterPNo = State.CurrentUser?.EmployeePNo ?? "";
        var result = await Api.PostAsync<MinuteSheetDetailDto>("api/v1/minute-sheets", model);
        saving = false;
        if (result.Success && result.Data != null) Nav.NavigateTo($"/minute-sheets/{result.Data.Id}");
        else error = result.Message;
    }

    private async Task SaveAndSubmit()
    {
        saving = true;
        error = null;
        model.RequesterPNo = State.CurrentUser?.EmployeePNo ?? "";
        var result = await Api.PostAsync<MinuteSheetDetailDto>("api/v1/minute-sheets", model);
        if (result.Success && result.Data != null)
        {
            var submitResult = await Api.PostAsync<MinuteSheetDetailDto>($"api/v1/minute-sheets/{result.Data.Id}/submit?requesterPNo={model.RequesterPNo}");
            saving = false;
            if (submitResult.Success) Nav.NavigateTo($"/minute-sheets/{result.Data.Id}");
            else error = submitResult.Message;
        }
        else { saving = false; error = result.Message; }
    }
}
