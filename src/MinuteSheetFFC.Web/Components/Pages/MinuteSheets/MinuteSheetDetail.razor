@page "/minute-sheets/{Id:int}"
@using MinuteSheetFFC.Application.DTOs.MinuteSheet
@using MinuteSheetFFC.Application.DTOs.Workflow
@using MinuteSheetFFC.Application.DTOs.Ai
@inject MinuteSheetFFC.Web.Services.ApiClient Api
@inject MinuteSheetFFC.Web.State.AppState State
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Minute Sheet - @(detail?.ReferenceNumber ?? "Loading")</PageTitle>

@if (detail == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>@detail.ReferenceNumber <span class="badge @GetBadge(detail.Status ?? "")">@detail.Status</span></h3>
            <small class="text-muted">Created @detail.CreatedAt.ToString("dd MMM yyyy HH:mm") by @detail.RequesterName</small>
        </div>
        <div class="d-flex gap-2">
            @if (detail.Status == "Draft")
            {
                <button class="btn btn-success btn-sm" @onclick="Submit">Submit</button>
            }
            @if (IsCurrentActioner && detail.Status == "InReview")
            {
                <button class="btn btn-primary btn-sm" @onclick="@(() => ShowAction("Reviewed"))">Review</button>
                <button class="btn btn-success btn-sm" @onclick="@(() => ShowAction("Approved"))">Approve</button>
                <button class="btn btn-danger btn-sm" @onclick="@(() => ShowAction("Rejected"))">Reject</button>
                <button class="btn btn-warning btn-sm" @onclick="@(() => ShowAction("Returned"))">Return</button>
            }
            @if (detail.Status == "Returned" && detail.RequesterPNo == State.CurrentUser?.EmployeePNo)
            {
                <button class="btn btn-info btn-sm" @onclick="Resubmit">Resubmit</button>
            }
            <button class="btn btn-outline-info btn-sm" @onclick="RunAiAnalysis">AI Analyze</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(actionMessage))
    {
        <div class="alert @(actionSuccess ? "alert-success" : "alert-danger")">@actionMessage</div>
    }

    @if (showActionModal)
    {
        <div class="card border-primary mb-3">
            <div class="card-header bg-primary text-white">Perform Action: @pendingAction</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Remarks</label>
                    <textarea class="form-control" rows="3" @bind="actionRemarks"></textarea>
                </div>
                <button class="btn btn-primary" @onclick="PerformAction">Confirm</button>
                <button class="btn btn-secondary ms-2" @onclick="CancelAction">Cancel</button>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header"><strong>Request Details</strong></div>
                <div class="card-body">
                    <h5>@detail.Subject</h5>
                    <div class="row mb-2">
                        <div class="col-md-3"><strong>Type:</strong> @detail.RequestTypeName</div>
                        <div class="col-md-3"><strong>Budget:</strong> @(detail.EstimatedBudget?.ToString("N0") ?? "N/A")</div>
                        <div class="col-md-3"><strong>Priority:</strong> @detail.Priority</div>
                        <div class="col-md-3"><strong>Mode:</strong> @detail.WorkflowMode</div>
                    </div>
                    <hr />
                    <div>@((MarkupString)(detail.Body ?? ""))</div>
                </div>
            </div>

            @if (aiResult != null)
            {
                <div class="card mb-3 border-info">
                    <div class="card-header bg-info text-white"><strong>AI Analysis</strong></div>
                    <div class="card-body">
                        <p><strong>Summary:</strong> @aiResult.Summary</p>
                        <div class="row">
                            <div class="col-md-4"><strong>Budget:</strong> @(aiResult.DetectedBudget?.ToString("N0") ?? "N/A")</div>
                            <div class="col-md-4"><strong>Urgency:</strong> @aiResult.Urgency</div>
                            <div class="col-md-4"><strong>Risk:</strong> @aiResult.RiskLevel</div>
                        </div>
                        @if (aiResult.MissingInformation?.Count > 0)
                        {
                            <h6 class="mt-2">Missing Information:</h6>
                            <ul>@foreach (var m in aiResult.MissingInformation) { <li>@m</li> }</ul>
                        }
                        @if (aiResult.RiskFlags?.Count > 0)
                        {
                            <h6>Risk Flags:</h6>
                            <ul>@foreach (var f in aiResult.RiskFlags) { <li class="text-danger">@f</li> }</ul>
                        }
                        @if (aiResult.ReviewerChecklist?.Count > 0)
                        {
                            <h6>Reviewer Checklist:</h6>
                            <ul>@foreach (var c in aiResult.ReviewerChecklist) { <li>@c</li> }</ul>
                        }
                    </div>
                </div>
            }

            <div class="card mb-3">
                <div class="card-header"><strong>Audit Trail</strong></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Time</th><th>Action</th><th>By</th><th>Status</th><th>Remarks</th></tr></thead>
                        <tbody>
                        @foreach (var h in detail.History)
                        {
                            <tr>
                                <td><small>@h.Timestamp.ToString("dd-MMM HH:mm")</small></td>
                                <td><span class="badge bg-secondary">@h.Action</span></td>
                                <td>@h.ActionerName</td>
                                <td>@h.PreviousStatus -> @h.NewStatus</td>
                                <td><small>@h.Remarks</small></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header"><strong>Approval Route</strong></div>
                <div class="card-body">
                    @if (detail.Stages.Count == 0)
                    {
                        <p class="text-muted">No stages generated yet.</p>
                    }
                    else
                    {
                        @foreach (var s in detail.Stages)
                        {
                            var borderClass = s.Status == "Active" ? "border-warning bg-light" : "";
                            <div class="d-flex align-items-start mb-2 p-2 border rounded @borderClass">
                                <div class="me-2">
                                    @if (s.Status == "Completed") { <span class="text-success fw-bold">&#10004;</span> }
                                    else if (s.Status == "Active") { <span class="text-warning fw-bold">&#9679;</span> }
                                    else if (s.Status == "Skipped") { <span class="text-muted">&#10008;</span> }
                                    else { <span class="text-muted">&#9675;</span> }
                                </div>
                                <div>
                                    <strong>@s.ActionerName</strong><br />
                                    <small class="text-muted">@s.ActionerDesignation - @s.ActionType</small><br />
                                    @if (s.Action != null)
                                    {
                                        <small><span class="badge bg-info">@s.Action</span> @s.ActionedAt?.ToString("dd-MMM HH:mm")</small>
                                    }
                                    @if (s.Remarks != null)
                                    {
                                        <br /><small class="text-muted fst-italic">@s.Remarks</small>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header"><strong>Attachments (@detail.Attachments.Count)</strong></div>
                <div class="card-body">
                    @if (detail.Attachments.Count == 0)
                    {
                        <p class="text-muted">No attachments.</p>
                    }
                    else
                    {
                        @foreach (var a in detail.Attachments)
                        {
                            <div class="mb-1"><small>@a.FileName (@((a.FileSize ?? 0L) / 1024) KB)</small></div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private MinuteSheetDetailDto? detail;
    private AiAnalysisDto? aiResult;
    private bool showActionModal;
    private string pendingAction = "";
    private string actionRemarks = "";
    private string? actionMessage;
    private bool actionSuccess;

    private bool IsCurrentActioner => detail?.CurrentActionerPNo == State.CurrentUser?.EmployeePNo;

    protected override async Task OnInitializedAsync() => await LoadDetail();

    private async Task LoadDetail()
    {
        var result = await Api.GetAsync<MinuteSheetDetailDto>($"api/v1/minute-sheets/{Id}");
        if (result.Success) detail = result.Data;
    }

    private void ShowAction(string action)
    {
        pendingAction = action;
        showActionModal = true;
        actionRemarks = "";
    }

    private void CancelAction() => showActionModal = false;

    private async Task PerformAction()
    {
        var dto = new WorkflowActionDto
        {
            ActionerPNo = State.CurrentUser?.EmployeePNo ?? "",
            ActionType = pendingAction,
            Remarks = actionRemarks
        };
        var result = await Api.PostAsync<WorkflowActionResultDto>($"api/v1/workflow/{Id}/action", dto);
        actionSuccess = result.Success;
        actionMessage = result.Success ? result.Data?.Message : result.Message;
        showActionModal = false;
        await LoadDetail();
    }

    private async Task Submit()
    {
        var pno = State.CurrentUser?.EmployeePNo ?? "";
        var result = await Api.PostAsync<MinuteSheetDetailDto>($"api/v1/minute-sheets/{Id}/submit?requesterPNo={pno}");
        actionSuccess = result.Success;
        actionMessage = result.Success ? "Submitted successfully." : result.Message;
        await LoadDetail();
    }

    private async Task Resubmit()
    {
        var pno = State.CurrentUser?.EmployeePNo ?? "";
        var result = await Api.PostAsync<MinuteSheetDetailDto>($"api/v1/minute-sheets/{Id}/resubmit?requesterPNo={pno}");
        actionSuccess = result.Success;
        actionMessage = result.Success ? "Resubmitted successfully." : result.Message;
        await LoadDetail();
    }

    private async Task RunAiAnalysis()
    {
        if (detail == null) return;
        var request = new AiAnalyzeRequestDto
        {
            Subject = detail.Subject,
            Body = detail.Body,
            EstimatedBudget = detail.EstimatedBudget,
            RequestType = detail.RequestTypeCode
        };
        var result = await Api.PostAsync<AiAnalysisDto>("api/v1/ai/analyze", request);
        if (result.Success) aiResult = result.Data;
    }

    private string GetBadge(string status) => status switch
    {
        "Draft" => "bg-secondary",
        "InReview" => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Returned" => "bg-info",
        "Cancelled" => "bg-dark",
        _ => "bg-secondary"
    };
}
