@page "/my-pending"
@rendermode InteractiveServer
@inject IEmployeeService EmployeeService
@inject IMinuteSheetService MinuteSheetService

<PageTitle>FFC Minute Sheet - My Actions</PageTitle>

<div class="page-stack">
    <section class="page-heading">
        <div>
            <nav class="breadcrumb-line" aria-label="Breadcrumb">
                <a href="/">Home</a>
                <i class="bi bi-chevron-right"></i>
                <strong>My Actions</strong>
            </nav>
            <h1>My Actions</h1>
        </div>
        <a class="btn btn-primary-ffc btn-lg px-4" href="minute-sheets/create">
            <i class="bi bi-plus-lg me-2"></i>
            New Request
        </a>
    </section>

    <section class="row g-3">
        <div class="col-12 col-md-4">
            <div class="surface-card metric-card">
                <div>
                    <p>Awaiting Me</p>
                    <strong>@items.Count</strong>
                </div>
                <span class="metric-icon text-primary bg-primary-subtle"><i class="bi bi-person-check"></i></span>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="surface-card metric-card accent-purple">
                <div>
                    <p>Urgent</p>
                    <strong>@items.Count(item => item.Priority == MinuteSheetPriority.Urgent)</strong>
                </div>
                <span class="metric-icon"><i class="bi bi-lightning-charge"></i></span>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="surface-card metric-card accent-green">
                <div>
                    <p>Returned</p>
                    <strong>@items.Count(item => item.Status == MinuteSheetStatus.Returned)</strong>
                </div>
                <span class="metric-icon"><i class="bi bi-arrow-return-left"></i></span>
            </div>
        </div>
    </section>

    <section class="surface-panel overflow-hidden">
        <div class="card-header-line">
            <h2><i class="bi bi-clipboard-check text-primary"></i> Pending Approval Queue</h2>
            <span class="text-muted fw-semibold">@items.Count item(s)</span>
        </div>
        <MinuteSheetTable Items="items" ShowRequester="true" EmptyText="No minute sheets are awaiting your action." />
    </section>
</div>

@code {
    private IReadOnlyList<MinuteSheetRecord> items = Array.Empty<MinuteSheetRecord>();

    protected override async Task OnInitializedAsync()
    {
        var user = await EmployeeService.GetCurrentEmployeeAsync();
        items = await MinuteSheetService.GetMyPendingActionsAsync(user.PNo);
    }
}
