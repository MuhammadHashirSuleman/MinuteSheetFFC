@if (Employee is not null && !string.IsNullOrWhiteSpace(Employee.AvatarUrl))
{
    <img class="avatar" style="@Style" src="@Employee.AvatarUrl" alt="@Employee.FullName" />
}
else
{
    <span class="avatar avatar-fallback" style="@Style">@ResolvedInitials</span>
}

@code {
    [Parameter]
    public EmployeeProfile? Employee { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? FallbackInitials { get; set; }

    [Parameter]
    public int Size { get; set; } = 32;

    private string Style => $"width: {Size}px; height: {Size}px;";

    private string ResolvedInitials => !string.IsNullOrWhiteSpace(Employee?.Initials)
        ? Employee.Initials
        : !string.IsNullOrWhiteSpace(FallbackInitials)
            ? FallbackInitials
            : CreateInitials(Name);

    private static string CreateInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "MS";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }
}
